APP_ENV=production
APP_URL=https://lanzabot.com
APP_SECRET=change_this_to_a_random_32_char_string

# Database
DB_HOST=localhost
DB_NAME=lanzabot
DB_USER=
DB_PASS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://lanzabot.com/auth/google/callback

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://lanzabot.com/auth/discord/callback

# Telegram Bot (for Login Widget)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Stripe
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create weekly recurring prices in Stripe dashboard)
STRIPE_PRICE_MEDIUM=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# Coolify
COOLIFY_HOST=https://your-coolify-instance.com
COOLIFY_API_KEY=
COOLIFY_SERVER_UUID=
COOLIFY_PROJECT_UUID=

# Coolify: UUIDs de los recursos de base de datos compartidos
# (obtener desde Coolify → Resources → su base de datos → URL contiene el UUID)
COOLIFY_POSTGRESQL_UUID=
COOLIFY_MONGODB_UUID=

# Conexión directa al servidor PostgreSQL compartido (admin)
# Host/puerto accesible desde este servidor PHP
SHARED_PG_HOST=
SHARED_PG_PORT=5432
SHARED_PG_ADMIN_USER=postgres
SHARED_PG_ADMIN_PASS=
SHARED_PG_ADMIN_DB=postgres

# Conexión directa al servidor MongoDB compartido (admin)
SHARED_MONGO_HOST=
SHARED_MONGO_PORT=27017
SHARED_MONGO_ADMIN_USER=root
SHARED_MONGO_ADMIN_PASS=

# Mail (SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=starttls
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=lanzabot.com
MAIL_REPLY_TO=
